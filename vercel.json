{
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/bigisub/:path*",
      "destination": "https://api.bigisub.ng/api/v2/:path*"
    },
    {
      "source": "/((?!api/|_expo/.*).*)",
      "destination": "/index.html"
    }
  ]
}